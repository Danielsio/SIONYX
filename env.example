# SIONYX Configuration Example
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env TO VERSION CONTROL!

# ============================================================================
# ARCHITECTURE: Multi-Tenant System
# ============================================================================
# ONE Firebase project serves MULTIPLE organizations
# Each organization is isolated by ORG_ID in the database path:
# organizations/{ORG_ID}/users/, organizations/{ORG_ID}/packages/, etc.
#
# To set up multiple organizations:
# 1. Use the SAME Firebase credentials
# 2. Use DIFFERENT ORG_IDs
# 3. Keep separate .env files (e.g., .env.org1, .env.org2)
# ============================================================================

# ============================================================================
# Organization Configuration (UNIQUE per installation)
# ============================================================================
# Unique identifier for THIS organization in the shared database
# Must be lowercase, letters/numbers/hyphens only
# Examples: tech-lab, school123, mycompany
ORG_ID=your-org-id

# ============================================================================
# Firebase Configuration (SAME for all organizations)
# ============================================================================
# Get these from Firebase Console:
# https://console.firebase.google.com/ → Project Settings → General
# These credentials are shared across all organizations

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id

# ============================================================================
# Payment Gateway Configuration (Nedarim Plus)
# ============================================================================
# Optional: Leave empty if you don't have payment gateway yet
# Get these from your Nedarim Plus account

NEDARIM_MOSAD_ID=your_mosad_id
NEDARIM_API_VALID=your_api_valid_key
NEDARIM_CALLBACK_URL=https://your-firebase-function-url/nedarimCallback

# ============================================================================
# Web App Configuration (for sionyx-web)
# ============================================================================
# No additional configuration needed for organization registration
# The web app uses Firebase Functions SDK directly (callable functions)

# ============================================================================
# Installation Instructions
# ============================================================================
# 
# Quick Start (Recommended):
#   Run the automated installer: python install.py
#
# Manual Setup:
#   1. Copy this file to .env
#   2. Fill in all the values above
#   3. Run: python tests/install_organization.py
#
# Web App Setup:
#   1. Deploy functions: firebase deploy --only functions
#   2. No additional configuration needed - uses Firebase SDK directly
#
# ============================================================================

