{
  "rules": {
    "config": {
      ".read": "auth != null",
      ".write": false
    },
    
    "organizations": {
      ".read": "root.child('config/superAdminUid').val() == auth.uid",
      ".write": "root.child('config/superAdminUid').val() == auth.uid",
      
      "$orgId": {
        "users": {
          ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
          ".indexOn": ["isActive", "createdAt", "lastSeen"],
          
          "$userId": {
            ".read": "auth.uid == $userId || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid",
            ".write": "auth.uid == $userId || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid",
            
            "isAdmin": {
              ".write": "root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid"
            }
          }
        },
        
        "packages": {
          ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
          ".indexOn": ["isActive", "createdAt"],
          
          "$packageId": {
            ".write": "root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid"
          }
        },
        
        "purchases": {
          ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
          ".indexOn": ["userId", "status", "createdAt"],
          
          "$purchaseId": {
            ".read": "data.child('userId').val() == auth.uid || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid",
            ".write": "(!data.exists() && newData.child('userId').val() == auth.uid) || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid"
          }
        },
        
        "messages": {
          ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
          ".indexOn": ["toUserId", "timestamp", "read"],

          "$messageId": {
            ".read": "auth != null && (data.child('toUserId').val() == auth.uid || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid)",
            ".write": "auth != null && (data.child('toUserId').val() == auth.uid || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid)",

            "read": {
              ".write": "data.child('toUserId').val() == auth.uid || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid"
            },

            "readAt": {
              ".write": "data.child('toUserId').val() == auth.uid || root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid"
            }
          }
        },
        
        "computers": {
          ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
          ".indexOn": ["isActive", "lastSeen", "computerName"],
          
          "$computerId": {
            ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
            ".write": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)"
          }
        },
        
        "metadata": {
          ".read": "auth != null && (root.child('organizations').child($orgId).child('users').child(auth.uid).exists() || root.child('config/superAdminUid').val() == auth.uid)",
          ".write": "root.child('organizations').child($orgId).child('users').child(auth.uid).child('isAdmin').val() === true || root.child('config/superAdminUid').val() == auth.uid",
          ".validate": "newData.hasChildren(['name', 'nedarim_mosad_id', 'nedarim_api_valid', 'created_at', 'status'])",
          
          "name": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "nedarim_mosad_id": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "nedarim_api_valid": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "created_at": {
            ".validate": "newData.isString()"
          },
          "status": {
            ".validate": "newData.isString() && newData.val() === 'active'"
          },
          "blackAndWhitePrice": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "colorPrice": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          }
        }
      }
    }
  }
}
